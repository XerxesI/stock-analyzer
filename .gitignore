# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/
ENV/

# Tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/

# Coverage
.coverage
.coverage.*
htmlcov/

# Jupyter
.ipynb_checkpoints/

# Environment and local config
.env
.env.*
*.local

# IDE / editor
.idea/
.vscode/

# Claude Code local (per-machine) settings — personal permission allowlist,
# not shareable. The shared .claude/settings.json stays tracked.
.claude/settings.local.json

# OS files
.DS_Store
Thumbs.db

# Logs
*.log

# Generated experiment outputs and feature datasets: reproducible from committed
# scripts + docs/09_experiments/*.md, not source-controlled project assets. See
# docs/09_experiments/SWING20_Phase1_Artifact_Manifest.md for checksums of key
# artifacts. (Files already tracked before this rule, e.g.
# artifacts/reports/frozen_c1_params.json, are unaffected -- gitignore only applies
# to untracked files.)
artifacts/

# Backups and archives (not source)
*.bak
*.zip
