# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/
ENV/

# Tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/

# Coverage
.coverage
.coverage.*
htmlcov/

# Jupyter
.ipynb_checkpoints/

# Environment and local config
.env
.env.*
*.local

# IDE / editor
.idea/
.vscode/

# Claude Code local (per-machine) settings — personal permission allowlist,
# not shareable. The shared .claude/settings.json stays tracked.
.claude/settings.local.json

# OS files
.DS_Store
Thumbs.db

# Logs
*.log

# Runtime metrics snapshot
runtime_metrics.json

# Backups and archives (not source)
*.bak
*.zip
